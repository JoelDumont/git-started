{
  "name": "git-started",
  "version": "1.0.0",
  "description": "Git tutorial documentation",
  "scripts": {
    "release": "semantic-release"
  },
  "devDependencies": {
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "semantic-release": "^23.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JoelDumont/git-started.git"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      {
        "preset": "angular"
      }
    ],
    "@semantic-release/github"
  }
}
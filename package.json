{
  "name": "git-started",
  "version": "1.0.0",
  "description": "Git tutorial documentation",
  "scripts": {
    "release": "semantic-release"
  },
  "devDependencies": {
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "semantic-release": "^23.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JoelDumont/git-started.git"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits",
          "releaseRules": [
            {
              "breaking": true,
              "release": "major"
            },
            {
              "type": "feat!",
              "release": "major"
            },
            {
              "type": "fix!",
              "release": "major"
            },
            {
              "type": "perf!",
              "release": "major"
            },
            {
              "type": "revert!",
              "release": "major"
            },
            {
              "type": "feat",
              "release": "minor"
            },
            {
              "type": "fix",
              "release": "patch"
            },
            {
              "type": "perf",
              "release": "patch"
            },
            {
              "type": "revert",
              "release": "patch"
            }
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/github"
    ]
  }
}